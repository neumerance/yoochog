# Copy this file to `.env.local` and set real values (never commit `.env.local`).
# Restart `npm run dev` after changes.

# Verbose `[yoochog:…]` console.log traces (also: localStorage `yoochog:debug:rtc` = "1", then reload).
# VITE_DEBUG_RTC=true

# Socket.io server base URL (scheme + host + port). Required for host/guest party sync.
# Local (host machine): point at the realtime server, e.g. after `docker compose up` (socket only), `docker compose -f compose.dev.yaml up` (web+socket), or `cd realtime-server && npm start`
# VITE_SOCKET_URL=http://localhost:3000

# Optional: YouTube Data API v3 key (browser-restricted) for resolving video titles on enqueue. When unset, titles show as unknown.
# VITE_YOUTUBE_API_KEY=
