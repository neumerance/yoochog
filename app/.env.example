# Copy this file to `.env.local` and set real values (never commit `.env.local`).
# Restart `npm run dev` after changes.

# PubNub (https://admin.pubnub.com/) — if both are set, PubNub is used for signaling.
VITE_PUBNUB_PUBLISH_KEY=
VITE_PUBNUB_SUBSCRIBE_KEY=

# Optional: local WebSocket relay (`signaling-dev`). Ignored when both PubNub keys are set.
# VITE_SIGNALING_URL=http://localhost:8787

# WebRTC ICE (STUN + optional TURN). See app/README.md — VITE_* values are bundled into the client.
# VITE_STUN_URLS=stun:stun.example:3478,stun:stun2.example:3478
# VITE_TURN_URLS=turn:turn.example:3478
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
